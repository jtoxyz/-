# Supabase Project Connection Details (Publicly accessible keys)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Server-side Administration Key (DO NOT expose to client, keep private)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Target student email domain configurations
# Comma-separated list of domains allowed to make reservations
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=ge.osaka-sandai.ac.jp,osaka-sandai.ac.jp

# The default domain used to auto-generate the email from the student ID
NEXT_PUBLIC_STUDENT_EMAIL_DOMAIN=ge.osaka-sandai.ac.jp
